global:
  resolve_timeout: 5m

route:
  receiver: 'default'
  group_by: ['alertname', 'severity']
  group_wait: 30s
  group_interval: 5m
  repeat_interval: 4h

# NOTE: Replace this with a real receiver (email, Slack, PagerDuty, etc.)
# Set alertmanager_webhook_url in group_vars to override.
receivers:
  - name: 'default'
    webhook_configs:
      - url: '{{ alertmanager_webhook_url | default("http://localhost:5001/") }}'
        send_resolved: true
