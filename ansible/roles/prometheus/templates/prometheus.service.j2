[Unit]
Description=Prometheus
Wants=network-online.target
After=network-online.target

[Service]
User={{ prometheus_user }}
Group={{ prometheus_group }}
Type=simple
ExecStart={{ prometheus_current_dir }}/prometheus --config.file={{ prometheus_config_dir }}/prometheus.yml --storage.tsdb.path={{ prometheus_data_dir }} --web.listen-address=0.0.0.0:{{ prometheus_port }}
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
